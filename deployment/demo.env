# ==============================================================================
# ASST MANAGEMENT SYSTEM - DEMO ENVIRONMENT CONFIGURATION
# ==============================================================================
# This file serves as a template for configuring the local or production environment
# variables. Rename this file to '.env' or use these keys in your AWS deployment
# (ECS Task definitions, EKS Secret YAMLs, Nginx environments, or EC2 instances).

# ------------------------------------------------------------------------------
# 1. Edge API Gateway & Authentication Settings
# ------------------------------------------------------------------------------
PORT=5005
JWT_SECRET=asst-jwt-secret-key-987654321_demo_change_in_prod

# Database Connection URL for Gateway Auth & Activity logging
# For Local: postgres://postgres:postgres@postgres:5432/auth_db?sslmode=disable
# For AWS RDS: postgresql://postgres:SecurePassword123@asst-db.xxxx.us-east-1.rds.amazonaws.com:5432/auth_db
DATABASE_URL=postgres://postgres:postgres@postgres:5432/auth_db?sslmode=disable

# ------------------------------------------------------------------------------
# 2. AWS S3 Storage Settings (Optional/Choice profile photos)
# ------------------------------------------------------------------------------
# Set these variables to upload profile avatars directly to Amazon S3.
# If omitted or left blank, the system automatically falls back to local disk storage (/uploads).
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1
AWS_S3_BUCKET=asst-user-avatars-demo

# ------------------------------------------------------------------------------
# 3. Codebase API Gateway Routing Proxy URLs
# ------------------------------------------------------------------------------
# These variables tell the codebase gateway-service proxy where to route requests.
# (If deploying using ALB path-based routing, these are bypassed).
ACADEMIC_SERVICE_URL=http://academic-service:8081
SCHEDULING_SERVICE_URL=http://scheduling-service:8082
LIBRARY_SERVICE_URL=http://library-service:8083
FINANCE_SERVICE_URL=http://finance-service:8084
INVENTORY_SERVICE_URL=http://inventory-service:8085
CAFE_SERVICE_URL=http://cafe-service:8086
ASSIGNMENT_QUIZ_SERVICE_URL=http://assignment-quiz-service:8001
RESEARCH_LAB_SERVICE_URL=http://research-lab-service:8002
PARKING_ALUMNI_SERVICE_URL=http://parking-alumni-service:8003
REPORT_SERVICE_URL=http://report-service:8004

# ------------------------------------------------------------------------------
# 4. Microservice Specific Database Connections
# ------------------------------------------------------------------------------
# Each service maintains its own isolated database instance.
# (For Go and Python microservices, database connections automatically support
# 'postgres://' or 'postgresql://' prefixes).

# Go Microservices
ACADEMIC_DATABASE_URL=postgres://postgres:postgres@postgres:5432/academic_db?sslmode=disable
SCHEDULING_DATABASE_URL=postgres://postgres:postgres@postgres:5432/schedule_db?sslmode=disable
LIBRARY_DATABASE_URL=postgres://postgres:postgres@postgres:5432/library_db?sslmode=disable
FINANCE_DATABASE_URL=postgres://postgres:postgres@postgres:5432/finance_db?sslmode=disable
INVENTORY_DATABASE_URL=postgres://postgres:postgres@postgres:5432/inventory_db?sslmode=disable
CAFE_DATABASE_URL=postgres://postgres:postgres@postgres:5432/cafe_db?sslmode=disable

# Python FastAPI Microservices
ASSIGNMENT_QUIZ_DATABASE_URL=postgres://postgres:postgres@postgres:5432/quiz_db?sslmode=disable
RESEARCH_LAB_DATABASE_URL=postgres://postgres:postgres@postgres:5432/research_db?sslmode=disable
PARKING_ALUMNI_DATABASE_URL=postgres://postgres:postgres@postgres:5432/parking_db?sslmode=disable

# ------------------------------------------------------------------------------
# 5. Frontend Client Build Variables
# ------------------------------------------------------------------------------
# Points the React portals to the public IP / URL of the API gateway.
# For local dev: http://localhost:5005
# For AWS deployment: http://your-alb-dns-name.amazonaws.com
VITE_API_GATEWAY_URL=http://localhost:5005
